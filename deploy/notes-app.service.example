# systemd service unit for inkfellow (Next.js)
# ─────────────────────────────────────────────────────────────────
# 1. Copy to /etc/systemd/system/notes-app.service
# 2. Edit User, WorkingDirectory, and EnvironmentFile to match your setup.
# 3. sudo systemctl daemon-reload
# 4. sudo systemctl enable --now notes-app
# ─────────────────────────────────────────────────────────────────

[Unit]
Description=inkfellow — Next.js Service
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/path/to/inkfellow
EnvironmentFile=/path/to/inkfellow/.env.local
ExecStart=/usr/bin/npm start
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
