{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "inkfellow",
  "version": "0.4.0",
  "identifier": "com.inkfellow.app",
  "build": {
    "frontendDist": "../desktop-lite",
    "beforeBuildCommand": "npm run desktop:prepare"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "inkfellow",
        "url": "index.html?v=20260609-image",
        "width": 1200,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/node",
      "../desktop-bundle/claude-chat/**/*"
    ],
    "macOS": {}
  }
}
