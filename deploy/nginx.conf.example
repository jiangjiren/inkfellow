# Nginx reverse-proxy configuration for Notes App
# ─────────────────────────────────────────────────────────────────
# Option A — With a domain + HTTPS (recommended for production)
# Option B — With a public IP only (no domain required)
#
# Replace all placeholders in ALL_CAPS before use.
# ─────────────────────────────────────────────────────────────────

# ── Option A: Domain + HTTPS (Certbot / Let's Encrypt) ───────────
server {
    listen 80;
    server_name YOUR_DOMAIN.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name YOUR_DOMAIN.com;

    ssl_certificate     /etc/letsencrypt/live/YOUR_DOMAIN.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # Proxy all traffic to the Next.js app
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}


# ── Option B: Public IP only (HTTP, no domain) ───────────────────
# Use this block if you don't have a domain yet.
# Set SITE_URL=http://YOUR_PUBLIC_IP in .env.local.
#
# server {
#     listen 80;
#     server_name YOUR_PUBLIC_IP;
#
#     location / {
#         proxy_pass         http://127.0.0.1:3000;
#         proxy_http_version 1.1;
#         proxy_set_header   Upgrade $http_upgrade;
#         proxy_set_header   Connection 'upgrade';
#         proxy_set_header   Host $host;
#         proxy_set_header   X-Real-IP $remote_addr;
#         proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
#         proxy_set_header   X-Forwarded-Proto $scheme;
#         proxy_cache_bypass $http_upgrade;
#     }
# }
#
# Alternatively, skip Nginx entirely and expose Next.js directly:
#   set PORT=80 in .env.local, then open firewall port 80.
#   SITE_URL=http://YOUR_PUBLIC_IP
