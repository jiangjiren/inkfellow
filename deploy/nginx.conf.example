# Nginx reverse-proxy configuration for Notes App
# ─────────────────────────────────────────────────────────────────
# Option A — With a domain + HTTPS (recommended for production)
# Option B — With a public IP only (no domain required)
#
# Replace all placeholders in ALL_CAPS before use.
#
# ── Quick-start checklist ────────────────────────────────────────
# 1. Copy to /etc/nginx/sites-available/notes-app
# 2. sudo ln -s /etc/nginx/sites-available/notes-app /etc/nginx/sites-enabled/
# 3. Create the AI panel password file (see "Basic Auth" note below)
# 4. sudo nginx -t && sudo systemctl reload nginx
# ─────────────────────────────────────────────────────────────────

# ── Option A: Domain + HTTPS (Certbot / Let's Encrypt) ───────────
server {
    listen 80;
    server_name YOUR_DOMAIN.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name YOUR_DOMAIN.com;

    ssl_certificate     /etc/letsencrypt/live/YOUR_DOMAIN.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # ── Notes App (Next.js on port 3000) ─────────────────────────
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # ── AI Assistant Panel (claude-chat on port 8082) ─────────────
    #
    # The AI panel uses WebSocket for real-time streaming.
    # The "Upgrade" and "Connection" headers are REQUIRED — without
    # them, WebSocket handshakes fail and the chat will not connect.
    #
    # Basic Auth is recommended here: the AI panel can consume API
    # credits, so restricting access is good practice.
    #
    # Generate the password file before enabling:
    #   echo "YOUR_USER:$(openssl passwd -apr1 YOUR_PASSWORD)" | sudo tee /etc/nginx/.htpasswd
    #
    location /notes-claude/ {
        auth_basic           "AI Assistant";
        auth_basic_user_file /etc/nginx/.htpasswd;

        proxy_pass         http://127.0.0.1:8082/;   # trailing slash strips the prefix
        proxy_http_version 1.1;

        # Required for WebSocket upgrade
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection "upgrade";

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}


# ── Option B: Public IP only (HTTP, no domain) ───────────────────
# Use this block if you don't have a domain yet.
# Set SITE_URL=http://YOUR_PUBLIC_IP in .env.local.
