# ─────────────────────────────────────────────
# inkfellow — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────

# App display name shown in the UI, page titles, and share link headers.
# Optional. Defaults to "inkfellow".
NEXT_PUBLIC_APP_NAME=inkfellow

# Required for /notes and /api/notes.
# Use an absolute path to an Obsidian-compatible Markdown vault.
VAULT_PATH=/absolute/path/to/your/vault

# Optional. Where share tokens are stored. Defaults to ./shared-notes.json.
# SHARED_NOTES_PATH=./shared-notes.json

# Optional. Public base URL used when generating share links.
# Use your domain, or your server's public IP (with port if not 80/443).
# Examples:
#   SITE_URL=https://example.com
#   SITE_URL=http://203.0.113.42
#   SITE_URL=http://203.0.113.42:3000
SITE_URL=http://localhost:3000

# Required to access /notes and /api/notes.
NOTES_BASIC_AUTH_USERNAME=notes
NOTES_BASIC_AUTH_PASSWORD=change-me

# Optional. Target used by the Git sync "push" action.
NOTES_GIT_PUSH_TARGET=HEAD:main

# Optional. Cloudflare Web Analytics token.
NEXT_PUBLIC_CF_WEB_ANALYTICS_TOKEN=
