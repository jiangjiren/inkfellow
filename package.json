{
  "name": "inkfellow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node -e \"const fs = require('fs'); if(fs.existsSync('.next/standalone')){fs.cpSync('public', '.next/standalone/public', {recursive: true}); fs.cpSync('.next/static', '.next/standalone/.next/static', {recursive: true});}\"",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "desktop:prepare": "node scripts/prepare-desktop-sidecar.mjs",
    "desktop:build": "npx -y @tauri-apps/cli build",
    "desktop:dev": "npx -y @tauri-apps/cli dev",
    "tauri:build": "npm run desktop:build"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "codemirror": "^5.65.21",
    "mermaid": "^11.15.0",
    "next": "^16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/codemirror": "^5.60.17",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "license": "AGPL-3.0",
  "author": "Jiang Jiren <jiangjiren@hotmail.com> (WeChat: jiangjiren)"
}
