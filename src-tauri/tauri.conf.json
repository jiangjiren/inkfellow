{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "inkfellow",
  "version": "0.1.0",
  "identifier": "com.inkfellow.app",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && node scripts/cleanup-standalone.js"
  },
  "app": {
    "windows": [
      {
        "title": "inkfellow",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/node.exe",
      "../.next/standalone/**/*",
      "../claude-chat/**/*"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
