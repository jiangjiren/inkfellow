PORT=8082
HOST=127.0.0.1

# Absolute path to the same vault used by the notes web app.
VAULT_PATH=/absolute/path/to/your/vault

# Authentication:
# Recommended for personal installs: log in with Claude Code using a Claude Pro/Max/Team/Enterprise account.
# Do not set ANTHROPIC_API_KEY if you want subscription credentials to be used.
# DeepSeek and OpenRouter API Keys can be configured from the web UI settings.

# Default is auto. Supported: plan, acceptEdits, auto, bypassPermissions.
# Use bypassPermissions only behind trusted auth.
CLAUDE_PERMISSION_MODE=auto

# Optional. Defaults to files in this directory.
CLAUDE_CHAT_SESSION_FILE=/absolute/path/to/session.json
CLAUDE_CHAT_HISTORY_FILE=/absolute/path/to/history.json
CLAUDE_CHAT_AUTH_PROFILE_FILE=/absolute/path/to/auth-profile.json
